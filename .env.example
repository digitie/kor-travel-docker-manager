# TripMate Manager 로컬 인프라 기본값

# 통합 PostgreSQL / PostGIS
KRADDR_GEO_DB_PORT=5432
KRADDR_GEO_POSTGRES_USER=addr
KRADDR_GEO_POSTGRES_PASSWORD=addr
KRADDR_GEO_POSTGRES_DB=kraddr_geo
KRADDR_GEO_PGDATA=/home/digitie/kraddr-geo-data/pgdata-final-20260529
KRADDR_JUSO_DATA=/mnt/f/dev/python-kraddr-geo/data/juso
KRADDR_GEO_STRICT_SOURCE_CHECK=1
KRADDR_GEO_SOURCE_DIR=/data/juso

# 통합 PostgreSQL 내부 앱별 database/role
TRIPMATE_POSTGRES_USER=tripmate
TRIPMATE_POSTGRES_PASSWORD=tripmate_dev_password
TRIPMATE_POSTGRES_DB=tripmate
TRIPMATE_AGENT_POSTGRES_DB=tripmate_agent
KRTOUR_MAP_POSTGRES_USER=krtour_map
KRTOUR_MAP_POSTGRES_PASSWORD=krtour_map_dev_password
KRTOUR_MAP_POSTGRES_DB=krtour_map

# RustFS 공용 오브젝트 스토리지
RUSTFS_API_PORT=12101
RUSTFS_API_CONTAINER_PORT=9000
RUSTFS_CONSOLE_PORT=12105
RUSTFS_CONSOLE_CONTAINER_PORT=9001
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_DATA_DIR=/home/digitie/kraddr-geo-data/rustfs
TRIPMATE_RUSTFS_BUCKET=tripmate-media
KRADDR_GEO_RUSTFS_BUCKET=kraddr-geo
KRADDR_GEO_RUSTFS_PREFIX=python-kraddr-geo
KRTOUR_MAP_RUSTFS_BUCKET=krtour-map
KRTOUR_MAP_OFFLINE_UPLOAD_BUCKET=krtour-uploads

# python-kraddr-geo API / Web UI
KRADDR_GEO_REPO_DIR=../python-kraddr-geo
KRADDR_GEO_API_IMAGE=kraddr-geo-api:latest-main-gdal
KRADDR_GEO_UI_IMAGE=kraddr-geo-ui:latest-main
KRADDR_GEO_API_CONTAINER=kraddr-geo-api-latest
KRADDR_GEO_UI_CONTAINER=kraddr-geo-ui-latest
KRADDR_GEO_API_PORT=12201
KRADDR_GEO_API_CONTAINER_PORT=12201
KRADDR_GEO_UI_PORT=12205
KRADDR_GEO_UI_CONTAINER_PORT=12205
KRADDR_GEO_APP_DATA_DIR=/mnt/f/dev/python-kraddr-geo/data
KRADDR_GEO_DOCKER_PG_DSN=postgresql+psycopg://addr:addr@kraddr-geo-postgres:5432/kraddr_geo
KRADDR_GEO_GEOIP_GATE_MODE=off
KRADDR_GEO_OPS_TABLE_STATS_CAPTURE_INTERVAL_MINUTES=0
KRADDR_GEO_RUSTFS_ENABLED=1
KRADDR_GEO_UI_PUBLIC_API_BASE_URL=/api/proxy
KRADDR_GEO_VWORLD_API_KEY=
NEXT_PUBLIC_VWORLD_API_KEY=
