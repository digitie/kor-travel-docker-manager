TRIPMATE_AGENT_POSTGRES_DB=tripmate_agent
KRTOUR_MAP_POSTGRES_USER=krtour_map
KRTOUR_MAP_POSTGRES_PASSWORD=krtour_map_dev_password
KRTOUR_MAP_POSTGRES_DB=krtour_map

# RustFS 공용 오브젝트 스토리지
RUSTFS_API_PORT=12101
RUSTFS_API_CONTAINER_PORT=9000
RUSTFS_CONSOLE_PORT=12105
RUSTFS_CONSOLE_CONTAINER_PORT=9001
