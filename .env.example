# Kor Travel Docker Manager 로컬 인프라 기본값

# 도커 네트워크 모드: dev 기본값은 host. host 모드에서는 포트 NAT가 없으므로 각 컨테이너가
# 호스트 정규 포트에 직접 바인딩하고, 서비스 간 참조는 127.0.0.1:<포트>를 사용한다.
KTDM_DOCKER_NETWORK_MODE=host

# 매니저 앱 운영(prod) 공개 주소 설정
# 실제 운영 도메인은 저장소에 커밋하지 않고 gitignore된 .env / frontend/.env.production 에만 둔다.
# 백엔드 API가 허용할 대시보드 Origin (CORS, 콤마 구분).
# 로그인 세션 쿠키를 사용하므로 실제 프론트엔드 Origin만 지정한다.
#   예) 운영: KTDM_CORS_ALLOW_ORIGINS=https://manager.example.org
KTDM_CORS_ALLOW_ORIGINS=http://localhost:12905,http://127.0.0.1:12905
KTDM_FRONTEND_ORIGINS=http://localhost:12905,http://127.0.0.1:12905
KTDM_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
# (선택) 설정 시, 위 신뢰 CIDR에서 와도 이 시크릿 헤더(X-KTDM-Proxy-Secret)가 일치해야 X-Forwarded-*를
# 신뢰한다. host 네트워크의 로컬 프로세스가 loopback 출처로 헤더를 위조하는 것을 차단한다. 리버스 프록시에
# 동일 값을 헤더로 주입해야 한다. 미설정 시 CIDR 매칭만으로 신뢰(기존 동작).
KTDM_TRUSTED_PROXY_SECRET=

# 매니저 관리자 로그인. 실제 hash/secret은 gitignore된 .env에만 둔다.
# 비밀번호 hash 형식: pbkdf2_sha256:310000:<salt>:<hash>
# 기존 pbkdf2_sha256$310000$<salt>$<hash> 형식도 검증은 가능하지만,
# Docker Compose가 루트 .env의 $를 변수 보간으로 오해할 수 있어 새 값은 : 구분자를 사용한다.
KTDM_ADMIN_USERNAME=admin
KTDM_ADMIN_PASSWORD_HASH=
KTDM_SESSION_SECRET=
# 로그인/로그아웃/키 관리 감사 로그 보존 행 수 상한(초과분은 오래된 것부터 정리, <=0 이면 비활성).
KTDM_LOGIN_AUDIT_MAX_ROWS=5000
# 프론트엔드가 호출하는 백엔드 API 공개 주소는 frontend/.env.production 의 NEXT_PUBLIC_BACKEND_URL 에 둔다.
#   예) 운영: NEXT_PUBLIC_BACKEND_URL=https://manager-api.example.org

# 관리 대상 서비스별 운영(prod) 공개 주소.
# registry/대시보드가 이 값을 읽어 공개 URL을 표시한다. 실제 도메인은 gitignore된 .env 에만 둔다.
# (저장소에는 환경변수 이름만 커밋하고 값은 비워 두거나 example.org 플레이스홀더만 둔다.)
#   예) 운영:
#     KTDM_PROD_URL_GEO=https://geo.example.org
#     KTDM_PROD_URL_GEO_API=https://geo-api.example.org
#     KTDM_PROD_URL_GEO_DAGSTER=https://geo-dagster.example.org
#     KTDM_PROD_URL_CONCIERGE=https://concierge.example.org
#     KTDM_PROD_URL_CONCIERGE_API=https://concierge-api.example.org
#     KTDM_PROD_URL_CONCIERGE_MCP=https://concierge-mcp.example.org
#     KTDM_PROD_URL_MAP=https://map.example.org
#     KTDM_PROD_URL_MAP_API=https://map-api.example.org
#     KTDM_PROD_URL_MAP_DAGSTER=https://map-dagster.example.org
#     KTDM_PROD_URL_PINVI=https://pinvi.example.org
#     KTDM_PROD_URL_PINVI_API=https://pinvi-api.example.org
#     KTDM_PROD_URL_PINVI_DAGSTER=https://pinvi-dagster.example.org
#     KTDM_PROD_URL_GRAFANA=https://grafana.example.org
#     KTDM_PROD_URL_CADVISOR=https://cadvisor.example.org
#     KTDM_PROD_URL_PROMETHEUS=https://prometheus.example.org
#     KTDM_PROD_URL_S3=https://s3.example.org
#     KTDM_PROD_URL_S3_API=https://s3-api.example.org

# 통합 PostgreSQL / PostGIS
KOR_TRAVEL_GEO_DB_PORT=5432
KOR_TRAVEL_GEO_POSTGRES_USER=addr
KOR_TRAVEL_GEO_POSTGRES_PASSWORD=addr
KOR_TRAVEL_GEO_POSTGRES_DB=kor_travel_geo
KOR_TRAVEL_GEO_PGDATA=/home/digitie/kor-travel-geo-data/pgdata-final-20260529
KOR_TRAVEL_GEO_JUSO_DATA=/mnt/f/dev/kor-travel-geo/data/juso
KOR_TRAVEL_GEO_STRICT_SOURCE_CHECK=1
KOR_TRAVEL_GEO_SOURCE_DIR=/data/juso

# 통합 PostgreSQL 내부 앱별 database/role
PINVI_POSTGRES_USER=pinvi
PINVI_POSTGRES_PASSWORD=pinvi_dev_password
PINVI_POSTGRES_DB=pinvi
KOR_TRAVEL_CONCIERGE_POSTGRES_DB=kor_travel_concierge
KRTOUR_MAP_POSTGRES_USER=krtour_map
KRTOUR_MAP_POSTGRES_PASSWORD=krtour_map_dev_password
KRTOUR_MAP_POSTGRES_DB=krtour_map
KRTOUR_MAP_DAGSTER_POSTGRES_DB=krtour_map_dagster

# RustFS 공용 오브젝트 스토리지
# host 모드에서는 컨테이너 내부 포트도 호스트 정규 포트(12101/12105)에 직접 바인딩한다.
RUSTFS_API_PORT=12101
RUSTFS_API_CONTAINER_PORT=12101
RUSTFS_CONSOLE_PORT=12105
RUSTFS_CONSOLE_CONTAINER_PORT=12105
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_DATA_DIR=/home/digitie/kor-travel-geo-data/rustfs
PINVI_RUSTFS_BUCKET=pinvi-media
KOR_TRAVEL_GEO_RUSTFS_BUCKET=kor-travel-geo
KOR_TRAVEL_GEO_RUSTFS_PREFIX=kor-travel-geo
KOR_TRAVEL_CONCIERGE_RUSTFS_BUCKET=kor-travel-concierge
KRTOUR_MAP_RUSTFS_BUCKET=krtour-map
KRTOUR_MAP_OFFLINE_UPLOAD_BUCKET=krtour-uploads

# Kor Travel Geo API / Web UI
KOR_TRAVEL_GEO_REPO_DIR=../kor-travel-geo
KOR_TRAVEL_GEO_API_IMAGE=kor-travel-geo-api:latest-main-gdal
KOR_TRAVEL_GEO_UI_IMAGE=kor-travel-geo-ui:latest-main
KOR_TRAVEL_GEO_API_CONTAINER=kor-travel-geo-api-latest
KOR_TRAVEL_GEO_UI_CONTAINER=kor-travel-geo-ui-latest
KOR_TRAVEL_GEO_API_PORT=12501
KOR_TRAVEL_GEO_API_CONTAINER_PORT=12501
KOR_TRAVEL_GEO_UI_PORT=12505
KOR_TRAVEL_GEO_UI_CONTAINER_PORT=12505
KOR_TRAVEL_GEO_APP_DATA_DIR=/mnt/f/dev/kor-travel-geo/data
# T-290g: writable DB-backup dir shared by geo-api (restore/download/verify) and the Dagster
# db_backup op (writer), mounted at /app/data/backups (the app's backup_allowed_dirs). Must be
# writable by both containers — the api runs as root, the dagster runtime as appuser — so
# create it 0777 (e.g. `install -d -m 0777 <dir>`). Defaults to <APP_DATA_DIR>/backups.
KOR_TRAVEL_GEO_BACKUP_DIR=/mnt/f/dev/kor-travel-geo/data/backups
KOR_TRAVEL_GEO_DOCKER_PG_DSN=postgresql+psycopg://addr:addr@127.0.0.1:5432/kor_travel_geo
KOR_TRAVEL_GEO_GEOIP_GATE_MODE=off
KOR_TRAVEL_GEO_OPS_TABLE_STATS_CAPTURE_INTERVAL_MINUTES=0
KOR_TRAVEL_GEO_RUSTFS_ENABLED=1
KOR_TRAVEL_GEO_UI_PUBLIC_API_BASE_URL=/api/proxy
KOR_TRAVEL_GEO_VWORLD_API_KEY=
NEXT_PUBLIC_VWORLD_API_KEY=
KOR_TRAVEL_GEO_PUBLIC_API_KEY_CACHE_TTL_S=30
KOR_TRAVEL_GEO_ADMIN_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
KOR_TRAVEL_GEO_ADMIN_PROXY_SECRET=
# geo-api가 admin /admin/dagster iframe에 반환하는 브라우저 노출용 Dagster 공개 URL(KTG_DAGSTER_PUBLIC_URL).
# 미설정 시 compose 기본값은 비어 있고 geo-api는 내부 dagster_url로 폴백한다. prod에서는 LAN 라우터가
# TLS 종단하는 공개 도메인(예: https://geo-dagster.example.org/)을 gitignore된 로컬 .env에만 설정한다.
# 로컬 docker dev에서 내부 Dagster를 임베드하려면 내부 주소로 오버라이드:
#   KOR_TRAVEL_GEO_DAGSTER_PUBLIC_URL=http://127.0.0.1:12502
# Dagster scheduled_backup 온램프가 호출하는 geo admin API 주소(KTG_DAGSTER_ADMIN_API_URL). 미설정 시
# compose 기본값 http://127.0.0.1:12501(host network의 geo-api)을 사용한다. kor-travel-geo #444.
KOR_TRAVEL_GEO_DAGSTER_ADMIN_API_URL=
KOR_TRAVEL_GEO_UI_ADMIN_USERNAME=admin
# Geo UI가 $ 구분자 hash만 지원하는 경우 gitignore된 별도 env 파일에
# KTG_UI_ADMIN_PASSWORD_HASH를 둔다. compose env_file은 raw format으로 읽는다.
KOR_TRAVEL_GEO_UI_ENV_FILE=.env.kor-travel-geo-ui.local
KOR_TRAVEL_GEO_UI_SESSION_SECRET=

# 관측 스택 (Prometheus / Grafana / cAdvisor Exporter)
PROMETHEUS_IMAGE=prom/prometheus:v2.53.1
PROMETHEUS_CONTAINER=kor-travel-prometheus
PROMETHEUS_PORT=12401
PROMETHEUS_RUN_AS_USER=0
PROMETHEUS_DATA_DIR=/home/digitie/kor-travel-geo-data/prometheus
GRAFANA_IMAGE=grafana/grafana:11.1.4
GRAFANA_CONTAINER=kor-travel-grafana
GRAFANA_PORT=12205
GRAFANA_RUN_AS_USER=0
GRAFANA_DATA_DIR=/home/digitie/kor-travel-geo-data/grafana
# 로컬 dev 기본값(admin/admin). prod에서는 반드시 gitignore된 .env에서 강한 값으로 오버라이드한다
# (KTDM_ADMIN_PASSWORD_HASH / KTDM_SESSION_SECRET 와 동일한 원칙). Grafana는 12205 포트로 직접 노출된다.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
CADVISOR_IMAGE=gcr.io/cadvisor/cadvisor:v0.52.1
CADVISOR_CONTAINER=kor-travel-cadvisor
CADVISOR_PORT=12301

# Kor Travel Concierge API / MCP / Scheduler / Web UI
KOR_TRAVEL_CONCIERGE_REPO_DIR=../kor-travel-concierge
KOR_TRAVEL_CONCIERGE_API_IMAGE=kor-travel-concierge-api:latest-main
KOR_TRAVEL_CONCIERGE_MCP_IMAGE=kor-travel-concierge-mcp:latest-main
KOR_TRAVEL_CONCIERGE_SCHEDULER_IMAGE=kor-travel-concierge-scheduler:latest-main
KOR_TRAVEL_CONCIERGE_UI_IMAGE=kor-travel-concierge-ui:latest-main
KOR_TRAVEL_CONCIERGE_API_CONTAINER=kor-travel-concierge-api-latest
KOR_TRAVEL_CONCIERGE_MCP_CONTAINER=kor-travel-concierge-mcp-latest
KOR_TRAVEL_CONCIERGE_SCHEDULER_CONTAINER=kor-travel-concierge-scheduler-latest
KOR_TRAVEL_CONCIERGE_UI_CONTAINER=kor-travel-concierge-ui-latest
KOR_TRAVEL_CONCIERGE_API_PORT=12601
KOR_TRAVEL_CONCIERGE_MCP_PORT=12602
KOR_TRAVEL_CONCIERGE_UI_PORT=12605
KOR_TRAVEL_CONCIERGE_DOCKER_DATABASE_URL=postgresql+asyncpg://addr:addr@127.0.0.1:5432/kor_travel_concierge

# Kor Travel Map API / Dagster / Web UI
# host 모드 컨테이너 내부 포트도 호스트 정규 포트(12701/12702/12705)에 직접 바인딩한다.
KOR_TRAVEL_MAP_REPO_DIR=../kor-travel-map
KOR_TRAVEL_MAP_API_IMAGE=kor-travel-map-api:latest-main
KOR_TRAVEL_MAP_UI_IMAGE=kor-travel-map-ui:latest-main
KOR_TRAVEL_MAP_DAGSTER_IMAGE=kor-travel-map-dagster:latest-main
KOR_TRAVEL_MAP_DAGSTER_DAEMON_IMAGE=kor-travel-map-dagster-daemon:latest-main
KOR_TRAVEL_MAP_API_CONTAINER=kor-travel-map-api-latest
KOR_TRAVEL_MAP_UI_CONTAINER=kor-travel-map-ui-latest
KOR_TRAVEL_MAP_DAGSTER_CONTAINER=kor-travel-map-dagster-latest
KOR_TRAVEL_MAP_DAGSTER_DAEMON_CONTAINER=kor-travel-map-dagster-daemon-latest
KOR_TRAVEL_MAP_API_PORT=12701
KOR_TRAVEL_MAP_API_CONTAINER_PORT=12701
KOR_TRAVEL_MAP_DAGSTER_PORT=12702
KOR_TRAVEL_MAP_DAGSTER_CONTAINER_PORT=12702
KOR_TRAVEL_MAP_UI_PORT=12705
KOR_TRAVEL_MAP_UI_CONTAINER_PORT=12705
KOR_TRAVEL_MAP_DOCKER_PG_DSN=postgresql+asyncpg://krtour_map:krtour_map_dev_password@127.0.0.1:5432/krtour_map
KOR_TRAVEL_MAP_DOCKER_DAGSTER_PG_URL=postgresql://krtour_map:krtour_map_dev_password@127.0.0.1:5432/krtour_map_dagster
# kor-travel-map Dagster의 Concierge feature pull 전용 credential. Concierge에서 외부
# 소비자용 DB read scope 키를 발급해 이 한 곳에만 저장한다. BFF/operator용 static
# API_KEYS를 공유하거나 docker-compose.override.yml에 literal로 반복하지 않는다.
KOR_TRAVEL_MAP_KOR_TRAVEL_CONCIERGE_BASE_URL=http://127.0.0.1:12601
KOR_TRAVEL_MAP_KOR_TRAVEL_CONCIERGE_API_KEY=

# PinVi API / Web UI / Dagster
PINVI_REPO_DIR=../pinvi
PINVI_API_IMAGE=pinvi-api:latest-main
PINVI_WEB_IMAGE=pinvi-web:latest-main
PINVI_DAGSTER_IMAGE=pinvi-dagster:latest-main
PINVI_API_CONTAINER=pinvi-api-latest
PINVI_WEB_CONTAINER=pinvi-web-latest
PINVI_DAGSTER_CONTAINER=pinvi-dagster-latest
PINVI_API_PORT=12801
# PinVi WebSocket broadcast broker is process-local until a shared broker lands.
PINVI_API_WORKERS=1
# prod에서는 gitignore된 `.env`에서 public API/Web origin으로 덮어쓴다.
PINVI_PUBLIC_API_URL=http://127.0.0.1:12801
PINVI_CORS_ALLOWED_ORIGINS=["http://127.0.0.1:12805","http://localhost:12805"]
PINVI_DAGSTER_PORT=12802
PINVI_WEB_PORT=12805
PINVI_DOCKER_DATABASE_URL=postgresql+asyncpg://pinvi:pinvi_dev_password@127.0.0.1:5432/pinvi
PINVI_JWT_SECRET_KEY=pinvi-local-jwt-secret-32-bytes-minimum
